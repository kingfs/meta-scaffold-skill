}

func (r *Repository) GetByID(ctx context.Context, id string) (*domain.__BOUNDED_CONTEXT_PASCAL__, error) {
	row, err := r.client.__BOUNDED_CONTEXT_PASCAL__.
		Query().
		Where(__BOUNDED_CONTEXT_SNAKE__.IDEQ(id)).
		Only(ctx)
